# ── Database (CLI only — direct Postgres connection, bypasses RLS) ──────────
# Supabase → Project Settings → Database → "Direct connection" (port 5432).
# Used by Drizzle for migrations AND by the CLI for all writes.
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres"

# ── Supabase keys ───────────────────────────────────────────────────────────
# secret key is CLI-side only. publishable key + URL are for the FRONTEND.
SUPABASE_URL="https://[REF].supabase.co"
SUPABASE_SECRET_KEY=""
SUPABASE_PUBLISHABLE_KEY=""

# ── LLM normalization (Vercel AI SDK — provider-agnostic) ───────────────────
# LLM_MODEL is "provider:model-id"; provider is one of: openai, google.
#   openai:gpt-5-mini     google:gemini-3-flash     (cheap tiers; tune later)
# Key: set LLM_API_KEY, OR the provider's native var (OPENAI_API_KEY /
# GOOGLE_GENERATIVE_AI_API_KEY) — whichever you have.
LLM_MODEL="openai:gpt-5-mini"
LLM_API_KEY=""

# ── Geocoding (Google Places API New) ───────────────────────────────────────
# Google Cloud → enable "Places API (New)" → create key → enable billing.
GOOGLE_PLACES_API_KEY=""
# Optional: geocode rate cap (Text Search starts/min) to stay under your Places
# per-minute quota. Default 60. Raise if your quota allows; lower if throttled.
# GEOCODE_RPM="60"

# ── Comments (ScrapFly free tier) ───────────────────────────────────────────
SCRAPFLY_KEY=""

# ── Frontend (Vite — public, RLS-protected) ─────────────────────────────────
VITE_SUPABASE_URL=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
